---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <MainCard
    title="About ME"
    description="Developer & CTF player & Geomatics Technician"
    textOverlay="ABOUT"
    infoIcon="lucide:user"
  >
    <style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap');

  .about-wrapper { font-family: 'Space Mono', sans-serif; }
  .mono { font-family: 'Space Mono', monospace; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { opacity: 0; animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.18s; }
  .d3 { animation-delay: 0.28s; }
  .d4 { animation-delay: 0.38s; }
  .d5 { animation-delay: 0.48s; }

  .sep-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, oklch(var(--bc) / 0.12), transparent);
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: oklch(var(--bc) / 0.38);
    white-space: nowrap;
  }

  .avatar-ring {
    border-radius: 18px;
    padding: 3px;
    background: linear-gradient(
      135deg,
      oklch(var(--p) / 0.55),
      oklch(var(--bc) / 0.08)
    );
    display: inline-block;
  }
  .avatar-ring img {
    border-radius: 14px;
    display: block;
  }

  .tech-badge {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid oklch(var(--bc) / 0.16);
    background: oklch(var(--b1) / 0.55);
    color: oklch(var(--bc) / 0.6);
    transition: all 0.2s;
  }
  .tech-badge:hover {
    border-color: oklch(var(--bc) / 0.26);
    color: oklch(var(--bc) / 0.88);
    background: oklch(var(--b2) / 0.65);
  }

  /* Timeline */
  .timeline-item {
    display: flex;
    gap: 1.25rem;
    padding: 1rem 0.75rem;
    border-radius: 10px;
    transition: background 0.2s;
  }
  .timeline-item:hover { background: oklch(var(--b2) / 0.6); }

  .timeline-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 6px;
    flex-shrink: 0;
  }
  .dot-primary { background: oklch(var(--p) / 0.85); }
  .dot-muted   { background: oklch(var(--bc) / 0.22); }

  .timeline-line {
    width: 1px;
    background: oklch(var(--bc) / 0.12);
    margin: 0 auto;
  }

  /* Competition highlight */
  .comp-highlight {
    font-family: 'Space Mono', monospace;
    font-size: 0.67rem;
    padding: 2px 8px;
    border-radius: 999px;
    background: oklch(var(--p) / 0.14);
    border: 1px solid oklch(var(--p) / 0.28);
    color: oklch(var(--p) / 0.92);
    white-space: nowrap;
  }

  .year-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: oklch(var(--bc) / 0.38);
    white-space: nowrap;
  }

  /* Bio block */
  .bio-text {
    font-size: 0.95rem;
    line-height: 1.75;
    color: oklch(var(--bc) / 0.62);
  }
  .bio-text strong { color: oklch(var(--bc) / 0.88); font-weight: 700; }
</style>

    <div class="about-wrapper space-y-14 mb-10">

      <!-- Profile -->
      <section class="fade-up d1 flex flex-col md:flex-row gap-8 md:gap-10 items-center md:items-start">
        <div class="avatar-ring flex-shrink-0">
          <img
            src="https://avatars.githubusercontent.com/u/123066919?v=4"
            alt="I-Hung Wu"
            width="140"
            height="140"
          />
        </div>

        <div class="flex-1 text-center md:text-left space-y-4">
          <div>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-base-content/90">
              I-Hung Wu
            </h1>
            <p class="mono text-sm text-base-content/40 mt-1">// 此情吳計可消除</p>
          </div>

          <p class="bio-text max-w-xl">
            <strong>Geography Olympiad</strong> awardee turned security researcher. Started with GIS mapping and traffic flow analysis, expanded into web & app development, now deep in <strong>cybersecurity</strong>. Member of CTF teams <strong>ICEDTEA</strong> &amp; <strong>OhYeahSeC</strong>.
          </p>

          <div class="flex flex-wrap gap-2 justify-center md:justify-start pt-1">
            {["Python", "Node.js", "React", "GIS", "Cybersecurity"].map(t => (
              <span class="tech-badge">{t}</span>
            ))}
          </div>
        </div>
      </section>

      <!-- Education -->
      <section class="fade-up d2 space-y-5">
        <div class="flex items-center gap-3">
          <span class="section-label">education</span>
          <div class="flex-1 sep-line"></div>
        </div>

        <div class="space-y-0">
          {[
            {
              school: "National Cheng Kung University",
              dept: "Department of Computer Science and Information Engineering",
              period: "2026 Aug ~",
              active: false
            },
            {
              school: "National Taiwan Ocean University",
              dept: "Department of Computer Science and Engineering",
              period: "2025 Sep – 2026 Jun",
              active: true
            },
            {
              school: "National Taiwan University",
              dept: "Department of Geography",
              period: "2025 Sep ~",
              active: true
            },
            {
              school: "Taipei Municipal Minglun High School",
              dept: null,
              period: "2022 – 2025",
              active: false
            },
          ].map(({ school, dept, period, active }) => (
            <div class="timeline-item">
              <div class="flex flex-col items-center">
                <div class={`timeline-dot ${active ? "dot-primary" : "dot-muted"}`}></div>
                <div class="timeline-line flex-1 mt-2"></div>
              </div>
              <div class="flex-1 flex items-start justify-between gap-4 pb-2">
                <div>
                  <p class={`font-semibold text-base ${active ? "text-base-content/90" : "text-base-content/70"}`}>
                    {school}
                  </p>
                  {dept && <p class="mono text-xs text-base-content/40 mt-0.5">{dept}</p>}
                </div>
                <span class="year-tag mt-0.5">{period}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Competitions -->
      <section class="fade-up d3 space-y-5">
        <div class="flex items-center gap-3">
          <span class="section-label">competitions &amp; experience</span>
          <div class="flex-1 sep-line"></div>
        </div>

        <div class="space-y-0">
          {[
            { name: "AIS3 EOF FINAL",             result: "1st",  year: "2026", highlight: true  },
            { name: "HITCON CTF Exhibition",       result: "2nd",     year: "2025", highlight: false },
            { name: "全國技能競賽 55 網路安全",        result: "佳作",    year: "2025", highlight: false },
            { name: "AIS3 pre-exam",               result: "19th",    year: "2025", highlight: false },
            { name: "AIS3 EOF Final",              result: "5th",     year: "2025", highlight: false },
            { name: "北區技能競賽 55 網路安全",        result: "5th",     year: "2025", highlight: false },
            { name: "成大程式邀請賽",                 result: "決賽",    year: "2025", highlight: false },
            { name: "YTP Final",                   result: null,      year: "2025", highlight: false },
            { name: "AIS3 最佳專題",                 result: null,      year: "2024", highlight: false },
            { name: "HITCON CMT",                  result: "Attendee",year: "2024", highlight: false },
            { name: "AIS3 Junior 助教",             result: null,      year: "2024, 2025", highlight: false },
            { name: "Geography Olympiad Final",    result: "silver medalist", year: "2023", highlight: false },
            { name: "Physic Olympiad",             result: null,      year: "2023", highlight: false },
            { name: "AIS3 Junior",                 result: null,      year: "2023", highlight: false },
          ].map(({ name, result, year, highlight }) => (
            <div class="timeline-item">
              <div class="flex flex-col items-center">
                <div class={`timeline-dot ${highlight ? "dot-primary" : "dot-muted"}`}></div>
                <div class="timeline-line flex-1 mt-2"></div>
              </div>
              <div class="flex-1 flex items-center justify-between gap-4 pb-1">
                <div class="flex items-center gap-3 flex-wrap">
                  <p class={`font-semibold text-sm md:text-base ${highlight ? "text-base-content/90" : "text-base-content/65"}`}>
                    {name}
                  </p>
                  {result && (
                    highlight
                      ? <span class="comp-highlight">{result}</span>
                      : <span class="mono text-xs text-base-content/40">{result}</span>
                  )}
                </div>
                <span class="year-tag">{year}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

    </div>
  </MainCard>
</BaseLayout>