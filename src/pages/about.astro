---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <MainCard
    title="About ME"
    description="Developer & CTF player & Geomatics Technician"
    textOverlay="ABOUT"
    infoIcon="lucide:user"
  >
    <div class="space-y-10 mb-8">
      <!-- Profile -->
      <section class="flex flex-col md:flex-row gap-8 items-center md:items-start">
        <div class="avatar">
          <div
            class="w-32 h-32 md:w-40 md:h-40 rounded-2xl ring ring-primary/60 ring-offset-base-100 ring-offset-2 overflow-hidden"
          >
            <img
              src="https://avatars.githubusercontent.com/u/123066919?v=4"
              alt=""
              width="160"
              height="160"
              loading="eager"
            />
          </div>
        </div>

        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl font-mono font-bold tracking-tight mb-2">I-Hung Wu</h1>
          <p class="font-mono text-base-content/70 mb-5">
            Developer & Geomatics Technician <br>
            Member of teams ICEDTEA & OhYeahSeC
          </p>
          <p class="text-base-content/75 leading-relaxed">
            I am a 2023 Geography Olympiad awardee. Initially, I focused on geographical research, including traffic flow analysis, GIS mapping, and applications. Later, I expanded my expertise to APP and web development. Currently, my primary focus is on cybersecurity, exploring its various technologies and challenges.
          </p>

          <div class="mt-5 flex flex-wrap gap-2 justify-center md:justify-start">
            <span class="badge badge-outline font-mono">Python</span>
            <span class="badge badge-outline font-mono">React</span>
            <span class="badge badge-outline font-mono">Node.js</span>
            <span class="badge badge-outline font-mono">GIS</span>
            <span class="badge badge-outline font-mono">Cybersecurity</span>
          </div>
        </div>
      </section>

      <!-- <div class="divider opacity-40 my-2"></div> -->

      <!-- Simple sections like screenshot -->
      <section class="space-y-12">
        <!-- Education -->
        <div>
          <h2 class="text-center text-3xl md:text-3xl font-mono font-bold tracking-wide text-base-content/80">
            Education
          </h2>
          <div class="divider opacity-40 my-4"></div>

          <ul class="space-y-5">
            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-primary/70 mt-1"></div>
              <div class="flex-1 flex items-start justify-between gap-6">
                <div>
                  <p class="font-mono font-semibold text-base md:text-lg">
                    National Cheng Kung University
                  </p>
                  <p class="font-mono text-base-content/60">
                    Department of Computer Science and Information Engineering
                  </p>
                </div>
                <div class="font-mono text-base-content/60 whitespace-nowrap">
                  2026 ~
                </div>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-start justify-between gap-6">
                <div>
                  <p class="font-mono font-semibold text-base md:text-lg">
                    National Taiwan Ocean University
                  </p>
                  <p class="font-mono text-base-content/60">
                    Department of Computer Science and Engineering
                  </p>
                </div>
                <div class="font-mono text-base-content/60 whitespace-nowrap">
                  2025 ~ 2026
                </div>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-start justify-between gap-6">
                <div>
                  <p class="font-mono font-semibold text-base md:text-lg">
                    National Taiwan University
                  </p>
                  <p class="font-mono text-base-content/60">
                    Department of Geography
                  </p>
                </div>
                <div class="font-mono text-base-content/60 whitespace-nowrap">
                  2025 ~ 2026
                </div>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-start justify-between gap-6">
                <div>
                  <p class="font-mono font-semibold text-base md:text-lg">
                    Taipei Municipal Minglun High School
                  </p>
                </div>
                <div class="font-mono text-base-content/60 whitespace-nowrap">
                  2022 ~ 2025
                </div>
              </div>
            </li>
          </ul>
        </div>

        <!-- Competitions -->
        <div>
          <h2 class="text-center text-3xl md:text-3xl font-mono font-bold tracking-wide text-base-content/80">
            Competitions & Experience
          </h2>
          <div class="divider opacity-40 my-4"></div>

          <ul class="space-y-3">
            <!-- strong/highlighted -->
            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-primary/70 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">AIS3 EOF FINAL 1st</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2026</p>
              </div>
            </li>

            <li class="flex gap-4">
                            <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>

              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">HITCON CTF Exhibition 2nd</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2025</p>
              </div>
            </li>

             <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">全國技能競賽 55 網路安全 佳作</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2025</p>
              </div>
            </li>

            <li class="flex gap-4">
                            <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>

              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">AIS3 pre-exam 19th</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2025</p>
              </div>
            </li>

            <li class="flex gap-4">
                            <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>

              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">AIS3 EOF Final 5th</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2025</p>
              </div>
            </li>

            <li class="flex gap-4">
                            <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>

              <div class="flex-1 flex items-center justify-between gap-6">
