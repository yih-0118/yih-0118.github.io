              </div>
            </li>


            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">HITCON CMT · Attendee</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2024</p>
              </div>
            </li>


            <!-- CTF/teams/camps -->
            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">YTP Final</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2025</p>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
