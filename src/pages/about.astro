              </div>
            </li>

            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">AIS3 Junior 助教</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2024, 2025</p>
              </div>
            </li>
            
            <li class="flex gap-4">
              <div class="w-1 rounded-full bg-base-content/20 mt-1"></div>
              <div class="flex-1 flex items-center justify-between gap-6">
                <p class="font-mono font-semibold text-lg">AIS3 Junior</p>
                <p class="font-mono text-base-content/60 whitespace-nowrap">2023</p>
              </div>
            </li>
          </ul>
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>