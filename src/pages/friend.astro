---

<BaseLayout title="Friends">
  <CardGroup cols="1">
    <MainCard
      textOverlay="FRIENDS"
      infoIcon="lucide:link"
    >
      <div class="space-y-10">
        <!-- Friends -->
        <section>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            {friends.map((f) => (
              <FriendCard
                name={f.name}
                avatar={f.avatar}
                description={f.description}
                url={f.url}
                type={f.type}
              />
            ))}
          </div>
        </section>

