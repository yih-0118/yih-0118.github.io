---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <MainCard
    title="Home"
    description="I-Hung Wu · Cybersecurity / Web / App"
    textOverlay="HOME"
    infoIcon="lucide:home"
  >
    <style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap');

  .home-wrapper { font-family: 'Space Mono', sans-serif; }
  .mono { font-family: 'Space Mono', monospace; }

  @keyframes glitch {
    0%, 100% { clip-path: inset(0 0 100% 0); transform: translate(0); }
    20%       { clip-path: inset(33% 0 33% 0); transform: translate(-2px, 1px); }
    40%       { clip-path: inset(66% 0 0 0);   transform: translate(2px, -1px); }
    60%       { clip-path: inset(0 0 66% 0);   transform: translate(0); }
    80%       { clip-path: inset(33% 0 50% 0); transform: translate(1px, 2px); }
  }

  @keyframes glitch2 {
    0%, 100% { clip-path: inset(0 0 100% 0); transform: translate(0); }
    20%       { clip-path: inset(50% 0 20% 0); transform: translate(2px, -1px); color: oklch(var(--p) / 0.9); }
    40%       { clip-path: inset(10% 0 60% 0); transform: translate(-1px, 2px); color: oklch(var(--a) / 0.9); }
    60%       { clip-path: inset(70% 0 10% 0); transform: translate(0); }
    80%       { clip-path: inset(25% 0 45% 0); transform: translate(-2px, 1px); }
  }

  .glitch-wrapper {
    position: relative;
    display: inline-block;
  }
  .glitch-wrapper::before,
  .glitch-wrapper::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .glitch-wrapper:hover::before {
    opacity: 0.75;
    color: oklch(var(--p) / 0.9);
    animation: glitch 0.4s steps(2) forwards;
  }
  .glitch-wrapper:hover::after {
    opacity: 0.75;
    color: oklch(var(--a) / 0.9);
    animation: glitch2 0.4s steps(2) 0.05s forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up {
    opacity: 0;
    animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.35s; }
  .delay-4 { animation-delay: 0.5s; }
  .delay-5 { animation-delay: 0.65s; }

  /* Skill row hover */
  .skill-row {
    position: relative;
    overflow: hidden;
    transition: background 0.25s ease;
    border-radius: 10px;
    cursor: default;
  }

  .skill-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, oklch(var(--bc) / 0.08), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .skill-row:hover::before { transform: translateX(100%); }
  .skill-row:hover { background: oklch(var(--b2) / 0.6); }

  /* Active indicator pulse (theme-safe, no RGB var needed) */
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 oklch(var(--p) / 0.40); }
    50%      { box-shadow: 0 0 0 6px oklch(var(--p) / 0.00); }
  }
  .dot-active { animation: pulse 2.5s ease-in-out infinite; }

  /* Badge */
  .badge-pill {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    padding: 2px 10px;
    border-radius: 999px;
    border: 1px solid oklch(var(--bc) / 0.16);
    background: oklch(var(--b1) / 0.55);
    color: oklch(var(--bc) / 0.55);
    transition: all 0.2s;
  }
  .skill-row:hover .badge-pill {
    border-color: oklch(var(--bc) / 0.26);
    color: oklch(var(--bc) / 0.78);
    background: oklch(var(--b2) / 0.65);
  }

  /* Separator line */
  .sep-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, oklch(var(--bc) / 0.12), transparent);
  }

  /* Section label */
  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: oklch(var(--bc) / 0.38);
  }

  /* Link buttons */
  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid oklch(var(--bc) / 0.16);
    background: oklch(var(--b1) / 0.55);
    color: oklch(var(--bc) / 0.70);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .nav-btn:hover {
    background: oklch(var(--b2) / 0.72);
    border-color: oklch(var(--bc) / 0.28);
    color: oklch(var(--bc) / 0.92);
    transform: translateY(-1px);
  }

  /* Nickname tag */
  .nickname-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.82rem;
    color: oklch(var(--bc) / 0.55);
    background: oklch(var(--b1) / 0.55);
    border: 1px dashed oklch(var(--bc) / 0.20);
    border-radius: 6px;
    padding: 3px 10px;
    display: inline-block;
    margin-top: 6px;
    letter-spacing: 0.03em;
  }

  /* GitHub container */
  .github-container {
    border: 1px solid oklch(var(--bc) / 0.12);
    border-radius: 14px;
    background: oklch(var(--b1) / 0.40);
    padding: 1.5rem;
    transition: border-color 0.3s, background 0.3s;
  }
  .github-container:hover {
    border-color: oklch(var(--bc) / 0.18);
    background: oklch(var(--b2) / 0.50);
  }
</style>

    <div class="home-wrapper space-y-14 mb-10">

      <!-- HI Section -->
      <section class="fade-up delay-1 space-y-6 pt-2">
        <div class="flex items-center gap-3">
          <span class="section-label">intro</span>
          <div class="flex-1 sep-line"></div>
        </div>

        <div class="space-y-3">
          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-base-content/90 leading-[1.1]">
            <span class="glitch-wrapper" data-text="I-Hung Wu">I-Hung Wu</span>
            <span class="ml-3">👋</span>
          </h1>

          <div class="nickname-tag">// 此情吳計可消除</div>

          <p class="mono text-sm text-base-content/45 pt-1 max-w-md leading-relaxed">
            Building things at the intersection of security, web, and systems.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/about" class="nav-btn">
            <Icon name="lucide:user" class="w-3.5 h-3.5" />
            About
          </a>
          <a href="/blog" class="nav-btn">
            <Icon name="lucide:book-open" class="w-3.5 h-3.5" />
            Blog
          </a>
          <a href="https://github.com/yih-0118" target="_blank" rel="noopener noreferrer" class="nav-btn">
            <Icon name="lucide:github" class="w-3.5 h-3.5" />
            GitHub
          </a>
        </div>
      </section>

      <!-- Focus Areas -->
      <section class="fade-up delay-2 space-y-5">
        <div class="flex items-center gap-3">
          <span class="section-label">focus</span>
          <div class="flex-1 sep-line"></div>
        </div>

        <div class="space-y-1">
          {[
            { name: "Cybersecurity",           status: "Learning",    active: true },
            { name: "Web Development",         status: "Learning",  active: false },
            { name: "App Development",         status: "Learning",  active: false }
            // { name: "Competitive Programming", status: "Learning",  active: false },
          ].map(({ name, status, active }, i) => (
            <div class={`skill-row flex items-center justify-between px-4 py-3.5 delay-${i + 2}`}>
              <div class="flex items-center gap-4">
                <div
                  class={`w-2 h-2 rounded-full flex-shrink-0 ${active ? "bg-primary dot-active" : "bg-base-content/20"}`}
                />
                <span class={`text-base font-semibold ${active ? "text-base-content/90" : "text-base-content/60"}`}>
                  {name}
                </span>
              </div>
              <span class="badge-pill">{status}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- GitHub Stats -->
      <section class="fade-up delay-5 space-y-5">
        <div class="flex items-center gap-3">
          <span class="section-label">github</span>
          <div class="flex-1 sep-line"></div>
        </div>

        <div class="github-container">
          <GitHubStats username="yih-0118" />
        </div>
      </section>

    </div>
  </MainCard>
</BaseLayout>