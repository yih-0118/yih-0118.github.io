---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <MainCard
    title="About ME"
    description="Developer, Geomatics Technician."
    textOverlay="ABOUT"
    infoIcon="lucide:user"
  >
    <div class="space-y-12 mb-10">
      <!-- Profile Section -->
      <section class="flex flex-col md:flex-row gap-8 items-center md:items-start">
        <div class="avatar">
          <div
            class="w-32 h-32 md:w-44 md:h-44 rounded-2xl ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden shadow-lg"
          >
            <!-- TODO: 換成你的 GitHub 頭像 -->
            <img
              src="https://avatars.githubusercontent.com/u/123066919?v=4"
              alt="SunMaple"
              width="176"
              height="176"
              loading="eager"
            />
          </div>
        </div>

        <div class="flex-1 text-center md:text-left">
          <!-- TODO: 換成你的名字 -->
          <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-2">
            SunMaple
          </h1>

          <!-- TODO: 換成你的 tagline -->
          <p class="text-lg md:text-xl text-base-content/75 mb-4">
            Developer & Open-Source Enthusiast
          </p>

          <!-- Quick badges -->
          <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-6">
            <span class="badge badge-primary badge-outline gap-2">
              <Icon name="lucide:map" class="w-4 h-4" />
              Geomatics
            </span>
            <span class="badge badge-secondary badge-outline gap-2">
              <Icon name="lucide:code" class="w-4 h-4" />
              Web Dev
            </span>
            <span class="badge badge-accent badge-outline gap-2">
              <Icon name="lucide:sparkles" class="w-4 h-4" />
              Astro
            </span>
          </div>

          <!-- Social buttons -->
          <div class="flex flex-wrap gap-3 justify-center md:justify-start mb-6">
            <a
              href="https://github.com/EveSunMaple"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2 rounded-xl"
            >
              <Icon name="lucide:github" class="w-4 h-4" />
              <span>GitHub</span>
            </a>
            <a
              href="https://twitter.com/EveSunMaple"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2 rounded-xl"
            >
              <Icon name="lucide:twitter" class="w-4 h-4" />
              <span>Twitter</span>
            </a>
            <a
              href="mailto:evesunmaple@outlook.com"
              class="btn btn-sm btn-outline gap-2 rounded-xl"
            >
              <Icon name="lucide:mail" class="w-4 h-4" />
              <span>Email</span>
            </a>
          </div>

          <div class="prose max-w-none prose-p:leading-relaxed">
            <p class="text-base-content/80">
              <!-- TODO: 改成你的介紹 -->
              Hello! I'm SunMaple, a passionate developer focused on creating elegant, responsive, and efficient web
              applications. I'm the creator of the Frosti blog theme, a modern Astro-based theme for content creators. I
              love contributing to open-source projects and building tools that help others create beautiful digital
              experiences.
            </p>
          </div>
        </div>
      </section>

      <!-- Education + Experience (NEW) -->
      <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Education -->
        <div class="bg-base-200/60 rounded-2xl p-6 shadow-sm border border-base-300">
          <h2 class="text-2xl font-bold mb-5 flex items-center gap-2">
            <Icon name="lucide:graduation-cap" class="w-6 h-6 text-primary" />
            <span>Education</span>
          </h2>

          <div class="space-y-4">
            <!-- TODO: 把下面換成你的學歷 -->
            <div class="rounded-xl bg-base-100/70 border border-base-300 p-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div class="font-bold text-lg">National Taiwan Ocean University</div>
                <span class="badge badge-outline">2025 — Present</span>
              </div>
              <div class="text-base-content/70 mt-1">
                B.S. (or major) • Focus: Security / Web / GIS
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="badge badge-ghost">CTF</span>
                <span class="badge badge-ghost">Astro</span>
                <span class="badge badge-ghost">Data</span>
              </div>
            </div>

            <div class="rounded-xl bg-base-100/70 border border-base-300 p-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div class="font-bold text-lg">MLSH</div>
                <span class="badge badge-outline">—</span>
              </div>
              <div class="text-base-content/70 mt-1">
                <!-- TODO -->
                Geomatics / Research / Competitions
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="badge badge-ghost">GIS</span>
                <span class="badge badge-ghost">Research</span>
                <span class="badge badge-ghost">Olympiad</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Experience -->
        <div class="bg-base-200/60 rounded-2xl p-6 shadow-sm border border-base-300">
          <h2 class="text-2xl font-bold mb-5 flex items-center gap-2">
            <Icon name="lucide:briefcase" class="w-6 h-6 text-primary" />
            <span>Experience</span>
          </h2>

          <div class="space-y-4">
            <!-- TODO: 把下面換成你的經驗 -->
            <div class="rounded-xl bg-base-100/70 border border-base-300 p-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div class="font-bold text-lg">CTF / Security Research</div>
                <span class="badge badge-outline">2024 — Present</span>
              </div>
              <p class="text-base-content/70 mt-2 leading-relaxed">
                Focus on pwn / web / crypto. Build tooling with Python, pwntools, and reverse engineering workflows.
              </p>
              <ul class="mt-3 space-y-1 text-base-content/75">
                <li class="flex gap-2">
                  <Icon name="lucide:check" class="w-4 h-4 mt-1 text-primary" />
                  <span>Exploit development and binary analysis automation</span>
                </li>
                <li class="flex gap-2">
                  <Icon name="lucide:check" class="w-4 h-4 mt-1 text-primary" />
                  <span>Web security testing and secure coding</span>
                </li>
              </ul>
            </div>

            <div class="rounded-xl bg-base-100/70 border border-base-300 p-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div class="font-bold text-lg">Projects</div>
                <span class="badge badge-outline">Ongoing</span>
              </div>
              <p class="text-base-content/70 mt-2 leading-relaxed">
                Build modern web apps and tools: Metro UI, flashcards PWA, data pipelines, and dashboards.
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="badge badge-ghost">React</span>
                <span class="badge badge-ghost">Astro</span>
                <span class="badge badge-ghost">Docker</span>
                <span class="badge badge-ghost">Python</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- GitHub Stats -->
      <section class="bg-base-200/50 rounded-2xl p-6 border border-base-300">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:github" class="w-6 h-6 text-primary" />
          <span>GitHub Statistics</span>
        </h2>

        <GitHubStats username="EveSunMaple" showLanguages={false} showCommitGraph={true} />
      </section>

      <!-- Tech Stack -->
      <section class="bg-base-200/50 rounded-2xl p-6 border border-base-300">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:code-2" class="w-6 h-6 text-primary" />
          <span>Tech Stack</span>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {
            [
              { name: "Astro", icon: "simple-icons:astro", color: "oklch(0.5 0.2 300)" },
              { name: "JavaScript", icon: "simple-icons:javascript", color: "oklch(0.8 0.2 80)" },
              { name: "TypeScript", icon: "simple-icons:typescript", color: "oklch(0.6 0.2 250)" },
              { name: "React", icon: "simple-icons:react", color: "oklch(0.7 0.2 200)" },
              { name: "Node.js", icon: "simple-icons:nodedotjs", color: "oklch(0.7 0.2 140)" },
              { name: "TailwindCSS", icon: "simple-icons:tailwindcss", color: "oklch(0.6 0.2 220)" },
              { name: "HTML5", icon: "simple-icons:html5", color: "oklch(0.7 0.2 30)" },
              { name: "CSS3", icon: "simple-icons:css3", color: "oklch(0.7 0.2 220)" },
              { name: "Git", icon: "simple-icons:git", color: "oklch(0.7 0.2 30)" },
              { name: "C++", icon: "simple-icons:cplusplus", color: "oklch(0.6 0.2 240)" },
              { name: "C#", icon: "simple-icons:csharp", color: "oklch(0.6 0.2 160)" },
              { name: "Python", icon: "simple-icons:python", color: "oklch(0.7 0.2 250)" },
            ].map((tech) => (
              <div class="group flex flex-col items-center justify-center p-4 bg-base-100/60 border border-base-300 rounded-2xl hover:bg-base-100 transition-colors shadow-sm">
                <div class="text-3xl mb-2" style={`color: ${tech.color}`}>
                  <Icon name={tech.icon} class="w-10 h-10 group-hover:scale-105 transition-transform" />
                </div>
                <span class="text-sm font-semibold">{tech.name}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Contribution Activity -->
      <section class="bg-base-200/50 rounded-2xl p-6 border border-base-300">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:activity" class="w-6 h-6 text-primary" />
          <span>Recent Activity</span>
        </h2>

        <div class="bg-base-100/60 rounded-2xl p-6 overflow-x-auto border border-base-300">
          <div class="flex flex-col md:flex-row gap-8 md:gap-6 md:overflow-x-auto md:pb-2">
            {
              [
                {
                  date: "January 2024",
                  title: "Open Source Contributions",
                  desc: "Contributed to several open source projects, focusing on performance optimizations.",
                },
                {
                  date: "March 2024",
                  title: "Initiated Frosti Project",
                  desc: "Started development of the Frosti blog theme for Astro, focusing on modern design principles.",
                },
                {
                  date: "July 2024",
                  title: "Released Frosti v2",
                  desc: "Published version 2 with improved responsive design and extended plugin support.",
                },
                {
                  date: "March 2025",
                  title: "Released Frosti v3",
                  desc: "Launched version 3 of the Frosti blog theme with enhanced performance and new customization options.",
                },
              ].map((item, i) => (
                <div class="relative flex gap-4 pb-2 md:pb-0 md:min-w-[260px]">
                  <div class="flex flex-col items-center">
                    <div class="w-10 h-10 rounded-2xl bg-primary flex items-center justify-center text-primary-content text-lg font-bold shadow-sm">
                      {i + 1}
                    </div>
                    <div class="w-0.5 h-16 bg-base-300 mt-2 md:hidden" />
                  </div>
                  <div>
                    <div class="text-sm text-base-content/60 mb-1">{item.date}</div>
                    <h3 class="text-lg font-bold">{item.title}</h3>
                    <p class="text-base-content/80 mt-1 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>